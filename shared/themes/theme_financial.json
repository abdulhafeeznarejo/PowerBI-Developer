{
  "name": "Financial Analyst Theme — Abdul Hafeez",
  "dataColors": [
    "#1F3864",
    "#2E75B6",
    "#70AD47",
    "#ED7D31",
    "#FFC000",
    "#FF0000",
    "#7030A0",
    "#00B0F0"
  ],
  "background": "#FFFFFF",
  "foreground": "#1F3864",
  "tableAccent": "#2E75B6",
  "visualStyles": {
    "*": {
      "*": {
        "fontFamily": [{ "value": "Segoe UI" }],
        "fontSize":   [{ "value": 11 }]
      }
    },
    "card": {
      "*": {
        "calloutValue": [{
          "fontSize":   { "value": 32 },
          "fontFamily": { "value": "Segoe UI" },
          "color":      { "solid": { "color": "#1F3864" } }
        }],
        "label": [{
          "fontSize":   { "value": 12 },
          "color":      { "solid": { "color": "#595959" } }
        }]
      }
    },
    "columnChart": {
      "*": {
        "dataPoint": [{ "defaultColor": { "solid": { "color": "#2E75B6" } } }],
        "title": [{ "fontColor": { "solid": { "color": "#1F3864" } }, "fontSize": 13 }]
      }
    },
    "lineChart": {
      "*": {
        "dataPoint": [{ "defaultColor": { "solid": { "color": "#1F3864" } } }]
      }
    },
    "tableEx": {
      "*": {
        "header": [{
          "fontColor":       { "solid": { "color": "#FFFFFF" } },
          "backColor":       { "solid": { "color": "#1F3864" } },
          "fontFamily":      { "value": "Segoe UI" },
          "fontSize":        { "value": 11 },
          "fontBold":        { "value": true }
        }],
        "values": [{
          "fontColor":       { "solid": { "color": "#000000" } },
          "backColor":       { "solid": { "color": "#FFFFFF" } },
          "fontSize":        10
        }],
        "totals": [{
          "fontColor":       { "solid": { "color": "#1F3864" } },
          "backColor":       { "solid": { "color": "#BDD7EE" } },
          "fontBold":        { "value": true }
        }]
      }
    },
    "slicer": {
      "*": {
        "general":  [{ "outlineColor": { "solid": { "color": "#2E75B6" } } }],
        "header":   [{ "fontColor": { "solid": { "color": "#1F3864" } }, "background": { "solid": { "color": "#BDD7EE" } } }]
      }
    }
  },
  "textClasses": {
    "callout":  { "fontSize": 45, "fontFace": "Segoe UI", "color": "#1F3864" },
    "title":    { "fontSize": 16, "fontFace": "Segoe UI", "color": "#1F3864" },
    "header":   { "fontSize": 13, "fontFace": "Segoe UI", "color": "#2E75B6" },
    "label":    { "fontSize": 10, "fontFace": "Segoe UI", "color": "#595959" }
  }
}
